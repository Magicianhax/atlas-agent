# ATLAS Agent Environment Variables
# Copy this to .env and fill in your values

# Your EVM wallet address (the wallet ATLAS will manage)
ATLAS_WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE

# Private key for the wallet above (with 0x prefix)
# ⚠️ NEVER commit this. NEVER share this.
ATLAS_WALLET_PK=0xYOUR_PRIVATE_KEY_HERE

# Alchemy API key (free tier works fine)
# Get one at https://dashboard.alchemy.com
ALCHEMY_API_KEY=YOUR_ALCHEMY_KEY_HERE

# ATLAS Dashboard (local Next.js app)
ATLAS_DASHBOARD_URL=http://localhost:3100
ATLAS_API_KEY=your-dashboard-api-key-here
