# Database — local SQLite file or Turso remote URL
# For local: file:./atlas.db
# For Turso: libsql://your-db.turso.io
TURSO_DATABASE_URL=file:./atlas.db

# Only needed if using Turso cloud (leave empty for local SQLite)
TURSO_AUTH_TOKEN=

# Secret key for agent API endpoints (POST/PUT/DELETE requests)
# The agent sends this as x-api-key header to authenticate writes
API_SECRET=change-me-to-something-random

# Wallet address to track on-chain transactions via Alchemy
AGENT_WALLET=0xYourAgentWalletAddress

# Alchemy API key for fetching on-chain transaction history
ALCHEMY_API_KEY=your-alchemy-api-key
